# ============================================================================
# 1. DATABASE CONNECTION
# ============================================================================
# Note: When using Docker Compose, PGEDGE_DB_HOST must match the service name 'db'
PGEDGE_DB_1_NAME=database
PGEDGE_DB_1_HOST=db
PGEDGE_DB_1_PORT=5432
PGEDGE_DB_1_DATABASE=open_memory
PGEDGE_DB_1_USER=memory_admin
# Loaded from ./secrets/db_password by runtime wrappers (keep blank or placeholder)
PGEDGE_DB_1_PASSWORD=
PGEDGE_DB_1_SSLMODE=prefer
PGEDGE_DB_1_ALLOW_WRITES=true

# ============================================================================
# 2. EMBEDDING PROVIDER (VOYAGE AI)
# ============================================================================
PGEDGE_EMBEDDING_ENABLED=true
PGEDGE_EMBEDDING_PROVIDER=voyage
PGEDGE_EMBEDDING_MODEL=voyage-3
# Loaded from ./secrets/voyage_api_key by runtime wrappers
PGEDGE_VOYAGE_API_KEY=

# ============================================================================
# 3. AUTHENTICATION & ACCESS
# ============================================================================
# INIT_TOKENS: Comma-separated list for Claude/Mobile access
INIT_TOKENS=

# INIT_USERS: For the Web UI at http://localhost:8081 (format: username:password)
INIT_USERS=

# ============================================================================
# 4. LLM CLIENT CONFIG (What the AI uses to think)
# ============================================================================
PGEDGE_LLM_PROVIDER=anthropic
PGEDGE_LLM_MODEL=claude-3-5-sonnet-20240620
# Loaded from ./secrets/anthropic_api_key by runtime wrappers
PGEDGE_ANTHROPIC_API_KEY=

# ============================================================================
# 5. SERVER SETTINGS
# ============================================================================
PGEDGE_HTTP_ENABLED=true
PGEDGE_HTTP_ADDRESS=:8080
PGEDGE_TLS_ENABLED=false
